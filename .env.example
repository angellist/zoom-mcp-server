# Zoom MCP Server Configuration
# Choose ONE authentication method:

# Option 1: Server-to-Server OAuth (recommended)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Option 2: Static bearer token
# ZOOM_API_TOKEN=

# Transport (http or stdio, default: http)
MCP_TRANSPORT=http

# Server port (default: 3000)
PORT=3000
